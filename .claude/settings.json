{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git fetch -q origin master",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& './.claude/hooks/pedagogy-check.ps1'",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& './.claude/hooks/pedagogy-set.ps1'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
