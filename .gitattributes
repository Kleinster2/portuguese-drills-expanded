# Normalize all text files to LF in the repo and the working tree.
# Stops persistent CRLF/LF churn on Windows checkouts.
* text=auto eol=lf

# Explicit binaries (don't let auto-detection guess wrong)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mp3 binary
*.pdf binary
*.woff binary
*.woff2 binary
